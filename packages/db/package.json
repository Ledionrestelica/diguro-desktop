{
  "name": "@diguro/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:generate": "tsx --env-file=../../apps/api/.env.local ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=../../apps/api/.env.local src/migrate.ts",
    "db:push": "tsx --env-file=../../apps/api/.env.local ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx --env-file=../../apps/api/.env.local ./node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "tsx --env-file=../../apps/api/.env.local src/seed.ts",
    "db:reset": "tsx --env-file=../../apps/api/.env.local src/reset.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@diguro/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
