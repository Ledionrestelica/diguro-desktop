# ==============================================================================
# API — copy to apps/api/.env.local (never commit .env or .env.local)
# ==============================================================================

# --- Postgres ---
# Local dev (docker-compose): postgres://diguro:diguro@localhost:5433/diguro
# Prod: Neon pooled connection string
DATABASE_URL=postgres://diguro:diguro@localhost:5433/diguro

# --- Redis ---
# Local: redis://localhost:6379
# Prod: Upstash REDIS URL
REDIS_URL=redis://localhost:6379

# --- Object storage (S3 or MinIO locally) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=diguro
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Better-Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- CORS allowlist (comma-separated) ---
# Includes desktop origins and future web origin.
ALLOWED_ORIGINS=http://localhost:5173,app://./,file://

# --- Inngest ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# --- RAG providers ---
VOYAGE_API_KEY=
COHERE_API_KEY=

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
